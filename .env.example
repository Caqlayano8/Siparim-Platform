# Siparim — Ortam Değişkenleri
# Bu dosyayı kopyala: cp .env.example .env

POSTGRES_DB=siparim_db
POSTGRES_USER=siparim
POSTGRES_PASSWORD=BURAYA_GUCLU_SIFRE_YAZ

REDIS_PASSWORD=BURAYA_REDIS_SIFRESI_YAZ

# JWT
JWT_SECRET=BURAYA_EN_AZ_32_KARAKTER_SECRET_YAZ
JWT_EXPIRES_IN=7d

# Iyzico ödeme
IYZICO_API_KEY=your_iyzico_api_key_here
IYZICO_SECRET_KEY=your_iyzico_secret_key_here
IYZICO_BASE_URL=https://api.iyzipay.com

# Google Maps (backend için)
GOOGLE_MAPS_API_KEY=your_google_maps_api_key_here

# FCM Push Notifications
FCM_SERVER_KEY=your_fcm_server_key_here

# App URL
APP_URL=https://siparim.com.tr
